<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Shooting Heart</title>
<style>
body{
background:black;
margin:0;
overflow:hidden;
}

canvas{
display:block;
}
</style>
</head>

<body>
<canvas id="canvas"></canvas>

<script>
const canvas = document.getElementById("canvas");
const ctx = canvas.getContext("2d");

canvas.width = window.innerWidth;
canvas.height = window.innerHeight;

let x = 0;

function draw(){
ctx.clearRect(0,0,canvas.width,canvas.height);

ctx.fillStyle = "red";
ctx.font = "bold 80px Arial";
ctx.fillText("Welcome Day", x, canvas.height/2);

x += 2;

if(x > canvas.width){
x = -400;
}

requestAnimationFrame(draw);
}

draw();
</script>

</body>
</html>
